# react-custom-scrollbars@4.2.1 declares React 15/16 peers but this app runs React 18,
# which makes npm 7+ fail install with ERESOLVE. Accept the (working) resolution so that
# fresh clones, CI, and Dependabot installs succeed without a manual --legacy-peer-deps flag.
# Longer-term fix: replace react-custom-scrollbars with the React 18-compatible fork.
legacy-peer-deps=true
